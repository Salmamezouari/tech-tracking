{% extends 'base.html.twig' %}

{% block title %}Connexion — FiberTrack{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
  /* ============================================================
     FIBERTRACK — LOGIN PAGE
     Design Taiwan tech / réseau industriel
  ============================================================ */

  body {
    background: #0a0f1e;
    margin: 0;
    padding: 0;
  }

  .login-root {
    min-height: 100vh;
    background: #0a0f1e;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
    overflow: hidden;
    font-family: 'Noto Sans TC', sans-serif;
  }

  /* Grille de fond */
  .grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 200, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 200, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    pointer-events: none;
  }

  /* Carte SVG réseau en arrière-plan */
  .map-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.4;
  }

  /* ---- Carte principale ---- */
  .card {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 420px;
    background: rgba(10, 16, 40, 0.94);
    border: 1px solid rgba(0, 200, 255, 0.2);
    border-radius: 4px;
    padding: 2rem 2rem 1.75rem;
    transition: border-color 0.4s;
  }

  .card.mode-admin {
    border-color: rgba(255, 160, 0, 0.3);
  }

  /* Ligne de couleur en haut */
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, #00c8ff, #0066ff, transparent);
    transition: background 0.4s;
    border-radius: 4px 4px 0 0;
  }

  .card.mode-admin::before {
    background: linear-gradient(90deg, transparent, #ffa000, #ff6000, transparent);
  }

  /* Coins décoratifs */
  .corner-tl,
  .corner-br {
    position: absolute;
    width: 14px;
    height: 14px;
    transition: border-color 0.4s;
  }

  .corner-tl {
    top: -1px; left: -1px;
    border-top: 2px solid #00c8ff;
    border-left: 2px solid #00c8ff;
  }

  .corner-br {
    bottom: -1px; right: -1px;
    border-bottom: 2px solid #00c8ff;
    border-right: 2px solid #00c8ff;
  }

  .mode-admin .corner-tl,
  .mode-admin .corner-br {
    border-color: #ffa000;
  }

  /* ---- Brand ---- */
  .brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1.5rem;
  }

  .brand-icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .brand-name {
    font-family: 'Share Tech Mono', monospace;
    font-size: 14px;
    color: #00c8ff;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .brand-sub {
    font-size: 10px;
    color: rgba(0, 200, 255, 0.45);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-family: 'Share Tech Mono', monospace;
    margin-top: 2px;
  }

  .divider {
    width: 100%;
    height: 1px;
    background: rgba(0, 200, 255, 0.12);
    margin-bottom: 1.25rem;
    transition: background 0.4s;
  }

  .mode-admin .divider {
    background: rgba(255, 160, 0, 0.15);
  }

  /* ---- Sélecteur de rôle ---- */
  .role-selector {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-bottom: 1.1rem;
  }

  .role-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 10px 8px;
    background: rgba(0, 200, 255, 0.04);
    border: 1px solid rgba(0, 200, 255, 0.15);
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(0, 200, 255, 0.45);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .role-btn svg {
    opacity: 0.4;
    transition: opacity 0.2s;
  }

  .role-btn:hover:not(.active-tech):not(.active-admin) {
    background: rgba(0, 200, 255, 0.06);
    border-color: rgba(0, 200, 255, 0.3);
    color: rgba(0, 200, 255, 0.65);
  }

  .role-btn.active-tech {
    background: rgba(0, 200, 255, 0.1);
    border-color: rgba(0, 200, 255, 0.55);
    color: #00c8ff;
  }

  .role-btn.active-tech svg {
    opacity: 1;
  }

  .role-btn.active-admin {
    background: rgba(255, 160, 0, 0.1);
    border-color: rgba(255, 160, 0, 0.55);
    color: #ffa000;
  }

  .role-btn.active-admin svg {
    opacity: 1;
  }

  /* Badge de rôle actif */
  .role-indicator {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 2px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 1.1rem;
    border: 1px solid rgba(0, 200, 255, 0.25);
    color: rgba(0, 200, 255, 0.7);
    background: rgba(0, 200, 255, 0.06);
    transition: all 0.4s;
    width: 100%;
    box-sizing: border-box;
  }

  .role-indicator.admin {
    border-color: rgba(255, 160, 0, 0.3);
    color: rgba(255, 160, 0, 0.8);
    background: rgba(255, 160, 0, 0.08);
  }

  /* ---- En-tête du formulaire ---- */
  .title-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }

  .title {
    font-size: 17px;
    font-weight: 500;
    color: #e8f4ff;
    letter-spacing: 0.02em;
    transition: color 0.4s;
  }

  .mode-admin .title {
    color: #ffe8c0;
  }

  .sys-id {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(0, 200, 255, 0.35);
    letter-spacing: 0.1em;
    transition: color 0.4s;
  }

  .mode-admin .sys-id {
    color: rgba(255, 160, 0, 0.35);
  }

  /* ---- Message d'erreur ---- */
  .alert-error {
    background: rgba(220, 60, 60, 0.1);
    border: 1px solid rgba(220, 60, 60, 0.35);
    border-radius: 3px;
    padding: 8px 12px;
    margin-bottom: 1rem;
    font-size: 11px;
    color: #ff7070;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 0.05em;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  /* ---- Champs de formulaire ---- */
  .field-group {
    margin-bottom: 0.9rem;
  }

  .field-label {
    font-size: 10px;
    font-family: 'Share Tech Mono', monospace;
    color: rgba(0, 200, 255, 0.55);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 5px;
    display: block;
    transition: color 0.4s;
  }

  .mode-admin .field-label {
    color: rgba(255, 160, 0, 0.55);
  }

  .field-wrap {
    display: flex;
    align-items: center;
    background: rgba(0, 200, 255, 0.04);
    border: 1px solid rgba(0, 200, 255, 0.18);
    border-radius: 3px;
    padding: 0 12px;
    height: 42px;
    transition: all 0.3s;
  }

  .field-wrap:focus-within {
    border-color: rgba(0, 200, 255, 0.6);
    background: rgba(0, 200, 255, 0.07);
    box-shadow: 0 0 0 3px rgba(0, 200, 255, 0.06);
  }

  .mode-admin .field-wrap {
    background: rgba(255, 160, 0, 0.04);
    border-color: rgba(255, 160, 0, 0.18);
  }

  .mode-admin .field-wrap:focus-within {
    border-color: rgba(255, 160, 0, 0.6);
    background: rgba(255, 160, 0, 0.07);
    box-shadow: 0 0 0 3px rgba(255, 160, 0, 0.06);
  }

  .field-icon {
    width: 15px;
    height: 15px;
    margin-right: 10px;
    flex-shrink: 0;
    opacity: 0.4;
  }

  .field-wrap input {
    background: transparent;
    border: none;
    outline: none;
    color: #c8e8ff;
    font-size: 13px;
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 0.05em;
    flex: 1;
    width: 100%;
    transition: color 0.4s;
  }

  .mode-admin .field-wrap input {
    color: #ffe0a0;
  }

  .field-wrap input::placeholder {
    color: rgba(0, 200, 255, 0.2);
    font-size: 12px;
  }

  .mode-admin .field-wrap input::placeholder {
    color: rgba(255, 160, 0, 0.2);
  }

  /* ---- Options ---- */
  .options-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.1rem;
  }

  .remember {
    display: flex;
    align-items: center;
    gap: 7px;
    cursor: pointer;
  }

  .remember input[type="checkbox"] {
    width: 13px;
    height: 13px;
    accent-color: #00c8ff;
    cursor: pointer;
  }

  .mode-admin .remember input[type="checkbox"] {
    accent-color: #ffa000;
  }

  .remember span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(0, 200, 255, 0.45);
    letter-spacing: 0.08em;
    transition: color 0.4s;
  }

  .mode-admin .remember span {
    color: rgba(255, 160, 0, 0.45);
  }

  .forgot-link {
    font-size: 10px;
    color: rgba(0, 200, 255, 0.4);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: color 0.2s;
  }

  .forgot-link:hover {
    color: #00c8ff;
  }

  .mode-admin .forgot-link {
    color: rgba(255, 160, 0, 0.4);
  }

  .mode-admin .forgot-link:hover {
    color: #ffa000;
  }

  /* ---- Bouton de connexion ---- */
  .btn-login {
    width: 100%;
    height: 44px;
    background: rgba(0, 200, 255, 0.1);
    border: 1px solid rgba(0, 200, 255, 0.45);
    border-radius: 3px;
    color: #00c8ff;
    font-family: 'Share Tech Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 1.25rem;
  }

  .btn-login:hover {
    background: rgba(0, 200, 255, 0.18);
    border-color: rgba(0, 200, 255, 0.75);
    box-shadow: 0 0 16px rgba(0, 200, 255, 0.15);
  }

  .btn-login:active {
    transform: scale(0.99);
  }

  .btn-login.admin-mode {
    background: rgba(255, 160, 0, 0.1);
    border-color: rgba(255, 160, 0, 0.45);
    color: #ffa000;
  }

  .btn-login.admin-mode:hover {
    background: rgba(255, 160, 0, 0.18);
    border-color: rgba(255, 160, 0, 0.75);
    box-shadow: 0 0 16px rgba(255, 160, 0, 0.15);
  }

  /* ---- Pied de carte ---- */
  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .status-badge {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .dot-live {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00ff88;
    animation: pulse 2s infinite;
  }

  .status-text {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(0, 255, 136, 0.6);
    letter-spacing: 0.1em;
  }

  .version-text {
    font-family: 'Share Tech Mono', monospace;
    font-size: 10px;
    color: rgba(0, 200, 255, 0.2);
    letter-spacing: 0.1em;
  }

  /* ---- Animations ---- */
  .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    animation: pulse 1.8s infinite;
    flex-shrink: 0;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.3; transform: scale(0.6); }
  }

  /* Accessibilité */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
  }
</style>
{% endblock %}

{% block body %}

<main class="login-root" aria-label="Page de connexion FiberTrack">

  {# Grille décorative #}
  <div class="grid-bg" aria-hidden="true"></div>

  {# Carte réseau SVG en arrière-plan #}
  <svg class="map-overlay" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <circle cx="120" cy="180" r="3" fill="#00c8ff" opacity="0.5"/>
    <circle cx="340" cy="100" r="2.5" fill="#00c8ff" opacity="0.4"/>
    <circle cx="600" cy="200" r="4" fill="#00c8ff" opacity="0.55"/>
    <circle cx="840" cy="130" r="2.5" fill="#00c8ff" opacity="0.4"/>
    <circle cx="1050" cy="250" r="3" fill="#00c8ff" opacity="0.45"/>
    <circle cx="200" cy="450" r="2.5" fill="#00c8ff" opacity="0.35"/>
    <circle cx="750" cy="550" r="3.5" fill="#00ff88" opacity="0.6"/>
    <circle cx="450" cy="600" r="2" fill="#00c8ff" opacity="0.35"/>
    <circle cx="950" cy="480" r="3" fill="#00c8ff" opacity="0.4"/>
    <circle cx="100" cy="650" r="2" fill="#00c8ff" opacity="0.3"/>
    <circle cx="1100" cy="600" r="2.5" fill="#00c8ff" opacity="0.35"/>
    <line x1="120" y1="180" x2="340" y2="100" stroke="#00c8ff" stroke-width="0.6" opacity="0.15"/>
    <line x1="340" y1="100" x2="600" y2="200" stroke="#00c8ff" stroke-width="0.6" opacity="0.15"/>
    <line x1="600" y1="200" x2="840" y2="130" stroke="#00c8ff" stroke-width="0.6" opacity="0.12"/>
    <line x1="840" y1="130" x2="1050" y2="250" stroke="#00c8ff" stroke-width="0.6" opacity="0.12"/>
    <line x1="600" y1="200" x2="750" y2="550" stroke="#00c8ff" stroke-width="0.6" opacity="0.1"/>
    <line x1="750" y1="550" x2="950" y2="480" stroke="#00c8ff" stroke-width="0.6" opacity="0.1"/>
    <line x1="200" y1="450" x2="450" y2="600" stroke="#00c8ff" stroke-width="0.5" opacity="0.1"/>
    <line x1="120" y1="180" x2="200" y2="450" stroke="#00c8ff" stroke-width="0.5" opacity="0.08"/>
    <line x1="950" y1="480" x2="1100" y2="600" stroke="#00c8ff" stroke-width="0.5" opacity="0.08"/>
  </svg>

  {# ============================
     CARTE DE CONNEXION
  ============================ #}
  <div class="card" id="login-card">
    <div class="corner-tl" aria-hidden="true"></div>
    <div class="corner-br" aria-hidden="true"></div>

    {# Brand #}
    <div class="brand">
      <svg class="brand-icon" viewBox="0 0 40 40" fill="none" aria-hidden="true">
        <rect width="40" height="40" rx="3" fill="rgba(0,200,255,0.08)" stroke="rgba(0,200,255,0.25)" stroke-width="1"/>
        <circle cx="20" cy="20" r="8" stroke="#00c8ff" stroke-width="1.2" opacity="0.6"/>
        <circle cx="20" cy="20" r="3.5" fill="#00c8ff" opacity="0.85"/>
        <line x1="20" y1="4"  x2="20" y2="12" stroke="#00c8ff" stroke-width="1.2" opacity="0.4"/>
        <line x1="20" y1="28" x2="20" y2="36" stroke="#00c8ff" stroke-width="1.2" opacity="0.4"/>
        <line x1="4"  y1="20" x2="12" y2="20" stroke="#00c8ff" stroke-width="1.2" opacity="0.4"/>
        <line x1="28" y1="20" x2="36" y2="20" stroke="#00c8ff" stroke-width="1.2" opacity="0.4"/>
        <line x1="8"  y1="8"  x2="13" y2="13" stroke="#00c8ff" stroke-width="0.8" opacity="0.2"/>
        <line x1="27" y1="27" x2="32" y2="32" stroke="#00c8ff" stroke-width="0.8" opacity="0.2"/>
      </svg>
      <div>
        <div class="brand-name">FiberTrack</div>
        <div class="brand-sub">Système de gestion réseau</div>
      </div>
    </div>

    <div class="divider"></div>

    {# === Sélecteur de rôle === #}
    <div class="role-selector" role="group" aria-label="Sélection du type de compte">
      <button
        type="button"
        class="role-btn active-tech"
        id="btn-tech"
        aria-pressed="true"
        onclick="setRole('tech')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="8" r="4" stroke="#00c8ff" stroke-width="1.3"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#00c8ff" stroke-width="1.3" stroke-linecap="round"/>
          <rect x="6" y="16" width="4" height="2.5" rx="0.6" stroke="#00c8ff" stroke-width="0.9"/>
          <path d="M15 14.5l2.5 2-2.5 2" stroke="#00c8ff" stroke-width="1.1" stroke-linecap="round"/>
        </svg>
        Technicien
      </button>

      <button
        type="button"
        class="role-btn"
        id="btn-admin"
        aria-pressed="false"
        onclick="setRole('admin')"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="8" r="4" stroke="#ffa000" stroke-width="1.3"/>
          <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#ffa000" stroke-width="1.3" stroke-linecap="round"/>
          <path d="M9.5 14.5l2 2L15 12.5" stroke="#ffa000" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="18.5" cy="16.5" r="3" stroke="#ffa000" stroke-width="1"/>
          <line x1="18.5" y1="14.8" x2="18.5" y2="18.2" stroke="#ffa000" stroke-width="1"/>
          <line x1="16.8" y1="16.5" x2="20.2" y2="16.5" stroke="#ffa000" stroke-width="1"/>
        </svg>
        Administrateur
      </button>
    </div>

    {# Badge de rôle actif #}
    <div class="role-indicator" id="role-indicator" aria-live="polite">
      <span class="pulse-dot" aria-hidden="true"></span>
      <span id="role-label">Accès technicien · Interventions fibre optique</span>
    </div>

    {# Titre du formulaire #}
    <div class="title-row">
      <h1 class="title" id="form-title">Connexion technicien</h1>
      <span class="sys-id" id="sys-id" aria-hidden="true">TECH-TWN</span>
    </div>

    {# === Message d'erreur Symfony === #}
    {% if error %}
      <div class="alert-error" role="alert">
        <span aria-hidden="true">▪</span>
        {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
    {% endif %}

    {# === Formulaire de connexion === #}
    <form method="post" novalidate>

      {# Token CSRF Symfony #}
      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

      {# Champ rôle caché (optionnel — pour la logique applicative) #}
      <input type="hidden" name="_role" id="role-input" value="technicien">

      {# Email / identifiant #}
      <div class="field-group">
        <label class="field-label" for="inputEmail" id="label-email">
          Identifiant technicien
        </label>
        <div class="field-wrap">
          <svg class="field-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="1" y="3" width="14" height="10" rx="2" stroke="#00c8ff" stroke-width="1.1"/>
            <path d="M1 6l7 5 7-5" stroke="#00c8ff" stroke-width="1.1"/>
          </svg>
          <input
            type="email"
            id="inputEmail"
            name="email"
            value="{{ last_username }}"
            autocomplete="email"
            required
            placeholder="tech@fibernet.tw"
            aria-labelledby="label-email"
          >
        </div>
      </div>

      {# Mot de passe #}
      <div class="field-group">
        <label class="field-label" for="inputPassword">
          Mot de passe
        </label>
        <div class="field-wrap">
          <svg class="field-icon" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <rect x="2" y="7" width="12" height="8" rx="2" stroke="#00c8ff" stroke-width="1.1"/>
            <path d="M5 7V5.5a3 3 0 016 0V7" stroke="#00c8ff" stroke-width="1.1"/>
            <circle cx="8" cy="11" r="1.3" fill="#00c8ff" opacity="0.65"/>
          </svg>
          <input
            type="password"
            id="inputPassword"
            name="password"
            autocomplete="current-password"
            required
            placeholder="••••••••"
          >
        </div>
      </div>

      {# Options #}
      <div class="options-row">
        <label class="remember">
          <input type="checkbox" name="_remember_me">
          <span>Rester connecté</span>
        </label>
        <a href="#" class="forgot-link">Mot de passe oublié ?</a>
      </div>

      {# Bouton de soumission #}
      <button type="submit" class="btn-login" id="btn-login" aria-label="Se connecter">
        <span class="pulse-dot" aria-hidden="true"></span>
        <span id="btn-label">Accès technicien</span>
      </button>

    </form>

    {# Pied de carte — statut réseau #}
    <div class="footer-row">
      <div class="status-badge">
        <div class="dot-live" aria-hidden="true"></div>
        <span class="status-text" id="footer-status">
          Réseau actif · 48 techniciens en ligne
        </span>
