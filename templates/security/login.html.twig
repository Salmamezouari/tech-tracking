{% extends 'base.html.twig' %}

{% block title %}Connexion — FiberTrack{% endblock %}

{% block stylesheets %}
{{ parent() }}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">

<link rel="stylesheet" href="{{ asset('css/login.css') }}">
{% endblock %}

{% block body %}

<main class="login-root" aria-label="Page de connexion FiberTrack">

  <div class="grid-bg" aria-hidden="true"></div>

  <svg class="map-overlay" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <circle cx="120" cy="180" r="3" fill="#00c8ff" opacity="0.5"/>
    <circle cx="340" cy="100" r="2.5" fill="#00c8ff" opacity="0.4"/>
    <circle cx="600" cy="200" r="4" fill="#00c8ff" opacity="0.55"/>
    <circle cx="840" cy="130" r="2.5" fill="#00c8ff" opacity="0.4"/>
    <circle cx="1050" cy="250" r="3" fill="#00c8ff" opacity="0.45"/>
    <circle cx="200" cy="450" r="2.5" fill="#00c8ff" opacity="0.35"/>
    <circle cx="750" cy="550" r="3.5" fill="#00ff88" opacity="0.6"/>
    <circle cx="450" cy="600" r="2" fill="#00c8ff" opacity="0.35"/>
    <circle cx="950" cy="480" r="3" fill="#00c8ff" opacity="0.4"/>
    <circle cx="100" cy="650" r="2" fill="#00c8ff" opacity="0.3"/>
    <circle cx="1100" cy="600" r="2.5" fill="#00c8ff" opacity="0.35"/>
    <line x1="120" y1="180" x2="340" y2="100" stroke="#00c8ff" stroke-width="0.6" opacity="0.15"/>
    <line x1="340" y1="100" x2="600" y2="200" stroke="#00c8ff" stroke-width="0.6" opacity="0.15"/>
    <line x1="600" y1="200" x2="840" y2="130" stroke="#00c8ff" stroke-width="0.6" opacity="0.12"/>
    <line x1="840" y1="130" x2="1050" y2="250" stroke="#00c8ff" stroke-width="0.6" opacity="0.12"/>
  </svg>

  <div class="card" id="login-card">

    <div class="corner-tl"></div>
    <div class="corner-br"></div>

    <div class="brand">
      <svg class="brand-icon" viewBox="0 0 40 40" fill="none">
        <rect width="40" height="40" rx="3" fill="rgba(0,200,255,0.08)" stroke="rgba(0,200,255,0.25)" stroke-width="1"/>
        <circle cx="20" cy="20" r="8" stroke="#00c8ff" stroke-width="1.2" opacity="0.6"/>
        <circle cx="20" cy="20" r="3.5" fill="#00c8ff" opacity="0.85"/>
      </svg>

      <div>
        <div class="brand-name">FiberTrack</div>
        <div class="brand-sub">Système de gestion réseau</div>
      </div>
    </div>

    <div class="divider"></div>

    <div class="role-selector">
      <button type="button" class="role-btn active-tech" id="btn-tech" onclick="setRole('tech')">
        Technicien
      </button>

      <button type="button" class="role-btn" id="btn-admin" onclick="setRole('admin')">
        Administrateur
      </button>
    </div>

    <div class="role-indicator" id="role-indicator">
      <span id="role-label">Accès technicien · Interventions fibre optique</span>
    </div>

    <div class="title-row">
      <h1 class="title" id="form-title">Connexion technicien</h1>
      <span class="sys-id" id="sys-id">TECH-TWN</span>
    </div>

    {% if error %}
      <div class="alert-error">
        {{ error.messageKey|trans(error.messageData, 'security') }}
      </div>
    {% endif %}

    <form method="post">

      <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
      <input type="hidden" name="_role" id="role-input" value="technicien">

      <div class="field-group">
        <label class="field-label" for="inputEmail">Identifiant technicien</label>

        <div class="field-wrap">
          <input type="email" id="inputEmail" name="email" value="{{ last_username }}" required>
        </div>
      </div>

      <div class="field-group">
        <label class="field-label">Mot de passe</label>

        <div class="field-wrap">
          <input type="password" id="inputPassword" name="password" required>
        </div>
      </div>

      <div class="options-row">
        <label class="remember">
          <input type="checkbox" name="_remember_me">
          <span>Rester connecté</span>
        </label>
      </div>

      <button type="submit" class="btn-login" id="btn-login">
        Accès technicien
      </button>

    </form>

  </div>
</main>

<script>
(function () {
  var currentRole = 'tech';

  var ROLES = {
    tech: {
      cardClass: '',
      roleLabel: 'Accès technicien · Interventions fibre optique',
      formTitle: 'Connexion technicien',
      sysId: 'TECH-TWN',
      btnLabel: 'Accès technicien',
      roleInputValue: 'technicien'
    },
    admin: {
      cardClass: 'mode-admin',
      roleLabel: 'Accès administrateur · Panneau de contrôle',
      formTitle: 'Connexion administrateur',
      sysId: 'ADMIN-TWN',
      btnLabel: 'Accès administration',
      roleInputValue: 'admin'
    }
  };

  window.setRole = function (role) {
    currentRole = role;
    var cfg = ROLES[role];

    document.getElementById('login-card').className = 'card ' + cfg.cardClass;
    document.getElementById('role-label').textContent = cfg.roleLabel;
    document.getElementById('form-title').textContent = cfg.formTitle;
    document.getElementById('sys-id').textContent = cfg.sysId;
    document.getElementById('btn-login').textContent = cfg.btnLabel;
    document.getElementById('role-input').value = cfg.roleInputValue;
  };
})();
</script>

{% endblock %}