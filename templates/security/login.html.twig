{# ============================================================
   JavaScript — Bascule de rôle (aucun rechargement)
============================================================ #}
<script>
  (function () {
    var currentRole = 'tech';

    var ROLES = {
      tech: {
        cardClass:      '',
        btnTechClass:   'role-btn active-tech',
        btnAdminClass:  'role-btn',
        indicatorClass: 'role-indicator',
        roleLabel:      'Accès technicien · Interventions fibre optique',
        formTitle:      'Connexion technicien',
        sysId:          'TECH-TWN',
        btnClass:       'btn-login',
        btnLabel:       'Accès technicien',
        emailLabel:     'Identifiant technicien',
        emailPlaceholder: 'tech@fibernet.tw',
        footerStatus:   'Réseau actif · 48 techniciens en ligne',
        roleInputValue: 'technicien',
        techPressed:    'true',
        adminPressed:   'false'
      },
      admin: {
        cardClass:      'mode-admin',
        btnTechClass:   'role-btn',
        btnAdminClass:  'role-btn active-admin',
        indicatorClass: 'role-indicator admin',
        roleLabel:      'Accès administrateur · Panneau de contrôle',
        formTitle:      'Connexion administrateur',
        sysId:          'ADMIN-TWN',
        btnClass:       'btn-login admin-mode',
        btnLabel:       'Accès administration',
        emailLabel:     'Identifiant administrateur',
        emailPlaceholder: 'admin@fibernet.tw',
        footerStatus:   'Portail admin · Gestion réseau complet',
        roleInputValue: 'admin',
        techPressed:    'false',
        adminPressed:   'true'
      }
    };

    window.setRole = function (role) {
      if (role === currentRole) return;
      currentRole = role;

      var cfg = ROLES[role];

      document.getElementById('login-card').className      = 'card ' + cfg.cardClass;
      document.getElementById('btn-tech').className        = cfg.btnTechClass;
      document.getElementById('btn-admin').className       = cfg.btnAdminClass;
      document.getElementById('btn-tech').setAttribute('aria-pressed', cfg.techPressed);
      document.getElementById('btn-admin').setAttribute('aria-pressed', cfg.adminPressed);
      document.getElementById('role-indicator').className  = cfg.indicatorClass;
      document.getElementById('role-label').textContent    = cfg.roleLabel;
      document.getElementById('form-title').textContent    = cfg.formTitle;
      document.getElementById('sys-id').textContent        = cfg.sysId;
      document.getElementById('btn-login').className       = cfg.btnClass;
      document.getElementById('btn-label').textContent     = cfg.btnLabel;
      document.getElementById('label-email').textContent   = cfg.emailLabel;
      document.getElementById('inputEmail').placeholder    = cfg.emailPlaceholder;
      document.getElementById('footer-status').textContent = cfg.footerStatus;
      document.getElementById('role-input').value          = cfg.roleInputValue;
    };
  })();
</script>

{% endblock %}
