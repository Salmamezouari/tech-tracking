{% extends 'base.html.twig' %}

{% block title %}Edit Intervention{% endblock %}

{% block body %}

<h2>Modifier intervention</h2>

<form method="post">

    <input type="text" name="title" class="form-control mb-2"
           value="{{ intervention.title }}">

    <input type="text" name="client_name" class="form-control mb-2"
           value="{{ intervention.clientName }}">

    <input type="text" name="address" class="form-control mb-2"
           value="{{ intervention.address }}">

    <input type="text" name="status" class="form-control mb-2"
           value="{{ intervention.status }}">

    {# 📅 DATE #}
    <input type="datetime-local" name="scheduled_date" class="form-control mb-2"
           value="{{ intervention.scheduledDate ? intervention.scheduledDate|date('Y-m-d\\TH:i') : '' }}">

    {# 👨‍🔧 TECHNICIEN #}
    <select name="tech" class="form-control mb-3">
        <option value="">Aucun technicien</option>
        {% for user in users %}
            <option value="{{ user.id }}"
                {% if intervention.assignedTechnician and intervention.assignedTechnician.id == user.id %}
                    selected
                {% endif %}
            >
                {{ user.name }}
            </option>
        {% endfor %}
    </select>

    <button class="btn btn-success">Enregistrer</button>
    <a href="{{ path('interventions_list') }}" class="btn btn-secondary">Retour</a>

</form>

{% endblock %}