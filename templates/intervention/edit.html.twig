{% extends 'base.html.twig' %}

{% block title %}Edit Intervention{% endblock %}

{% block body %}

<h2>Modifier intervention</h2>

<form method="post">

    <input type="text" name="title" class="form-control mb-2"
           value="{{ intervention.title }}">

    <input type="text" name="description" class="form-control mb-2"
           value="{{ intervention.description }}">

    <input type="text" name="client_name" class="form-control mb-2"
           value="{{ intervention.clientName }}">

    <input type="text" name="address" class="form-control mb-2"
           value="{{ intervention.address }}">

    <input type="text" name="status" class="form-control mb-2"
           value="{{ intervention.status }}">

    <button class="btn btn-success">Enregistrer</button>
    <a href="{{ path('intervention_list') }}" class="btn btn-secondary">Retour</a>

</form>

{% endblock %}