{% extends 'base.html.twig' %}

{% block body %}
<h2>Mes interventions</h2>

<table class="table">
<tr>
    <th>Titre</th>
    <th>Status</th>
    <th>Action</th>
</tr>

{% for i in interventions %}
<tr>
    <td>{{ i.title }}</td>
    <td>{{ i.status }}</td>

    <td>
        <form method="post" action="/intervention/status/{{ i.id }}">
            <select name="status">
                <option>En cours</option>
                <option>Terminé</option>
            </select>
            <button class="btn btn-primary btn-sm">Update</button>
        </form>
    </td>
</tr>
{% endfor %}
</table>
{% endblock %}